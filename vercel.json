{
  "framework": "nextjs",
  "regions": ["iad1"],
  "installCommand": "npm install",
  "buildCommand": "npm run build",
  "outputDirectory": ".next",
  "github": {
    "silent": false
  },
  "functions": {
    "app/api/images/generate/route.ts": {
      "maxDuration": 60
    },
    "app/api/marketing/generate/route.ts": {
      "maxDuration": 45
    }
  },
  "rewrites": [
    {
      "source": "/healthz",
      "destination": "/api/health"
    }
  ]
}
